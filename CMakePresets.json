{
  "version": 6,
  "configurePresets": [
    {
      "name": "dev",
      "displayName": "Developer build",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build/dev",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "TBE_BUILD_TESTS": "ON",
        "TBE_BUILD_CLI": "ON",
        "TBE_ENABLE_OCCT": "ON"
      }
    },
    {
      "name": "release",
      "displayName": "Release build",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "TBE_BUILD_TESTS": "ON",
        "TBE_BUILD_CLI": "ON",
        "TBE_ENABLE_OCCT": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "dev",
      "configurePreset": "dev"
    },
    {
      "name": "release",
      "configurePreset": "release"
    }
  ],
  "testPresets": [
    {
      "name": "dev",
      "configurePreset": "dev",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}

